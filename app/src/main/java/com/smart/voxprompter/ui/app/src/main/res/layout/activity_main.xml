<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="16dp">

    <TextView
        android:id="@+id/appTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VoxPrompter Studio"
        android:textColor="#00E676"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ScrollView
        android:id="@+id/scriptScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:background="#1E1E1E"
        android:padding="12dp"
        app:layout_constraintBottom_toTopOf="@+id/textControlPanel"
        app:layout_constraintTop_toBottomOf="@+id/appTitle">

        <TextView
            android:id="@+id/tvPrompterText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="أهلاً بك في VoxPrompter! السكربت الخاص بك سيتحرك هنا تلقائياً عند البدء..."
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center" />
    </ScrollView>

    <LinearLayout
        android:id="@+id/textControlPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@+id/controlPanel">

        <Button
            android:id="@+id/btnTextDecrease"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="تصغير الخط -"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#455A64"
            android:textSize="12sp"/>

        <Button
            android:id="@+id/btnTextIncrease"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="تكبير الخط +"
            android:backgroundTint="#455A64"
            android:textSize="12sp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/controlPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnSpeedDown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ابطأ -"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#37474F"/>

        <Button
            android:id="@+id/btnPlayPause"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="تشغيل"
            android:backgroundTint="#00E676"
            android:textColor="#121212"
            android:textStyle="bold"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnSpeedUp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="أسرع +"
            android:backgroundTint="#37474F"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
        
